# ═══════════════════════════════════════════════════════════════════════════════
# MedCollab Backend — Environment Variables
# Copy to .env for local development. Set in Railway for production.
# Validate before deploy: node scripts/validate-env.js
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────────
# development | production
NODE_ENV=development

# Railway sets PORT automatically. Local default: 5000
PORT=5000

# Public HTTPS URL of this API (required in production if using local media fallback)
# Example: https://medcollab-api.up.railway.app
API_BASE_URL=http://localhost:5000

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (REQUIRED in production)
# Atlas → Connect → Drivers → copy URI, replace <password>
# Append database name: ...mongodb.net/medcollab?retryWrites=true&w=majority
#
# LOCAL DEV: leave empty to auto-start in-memory MongoDB (data resets on restart)
# PRODUCTION: must be set — mongodb-memory-server is NOT used in production
MONGODB_URI=

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── OTP (MSG91 — India) ──────────────────────────────────────────────────────
# REQUIRED for production login. Get keys from msg91.com dashboard.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# DEV ONLY: set true to accept OTP 123456 without SMS. NEVER true in production.
OTP_BYPASS=false
OTP_EXPIRY_MINUTES=10

# ─── Cloudinary (Media Storage) ───────────────────────────────────────────────
# REQUIRED for production beta — Railway disk is ephemeral.
# Leave blank in local dev to use uploads/ folder on disk.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Firebase (Push Notifications — optional for beta) ────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
OTP_RATE_LIMIT_MAX=5

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins for Flutter web / admin dashboard.
# Mobile apps (APK) do not send Origin — they are unaffected.
# Example: https://medcollab-web.up.railway.app,https://app.medcollab.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Optional ─────────────────────────────────────────────────────────────────
# MAX_FILE_SIZE_MB=25
